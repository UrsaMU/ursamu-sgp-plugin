{
  "tasks": {
    "test": "deno test -A --unstable-kv",
    "lint": "deno lint",
    "check": "deno check src/index.ts mod.ts index.ts",
    "showcase": "deno run -A --unstable-kv --import-map=showcase.importmap.json tools/showcase.ts"
  },
  "name": "@ursamu/globals",
  "version": "1.2.0",
  "description": "Rhost-style formatting for UrsaMU — look, who, where, page, mail, score, examine, inventory, +finger, +staff, ooc, +namecolor.",
  "exports": "./mod.ts",
  "publish": {
    "include": [
      "src",
      "scripts",
      "help",
      "mod.ts",
      "index.ts",
      "deno.json",
      "ursamu.plugin.json",
      "LICENSE",
      "README.md"
    ],
    "exclude": ["tests"]
  },
  "lint": {
    "exclude": ["scripts/"]
  },
  "fmt": {
    "exclude": ["scripts/"]
  },
  "imports": {
    "@ursamu/ursamu":   "jsr:@ursamu/ursamu@^2.3",
    "@ursamu/mushcode": "jsr:@ursamu/mushcode",
    "@std/assert":      "jsr:@std/assert@^0.224.0",
    "@std/testing/bdd": "jsr:@std/testing@^0.224.0/bdd",
    "@std/path":        "jsr:@std/path@^0.224.0",
    "@std/fs":          "jsr:@std/fs@^0.224.0"
  }
}
